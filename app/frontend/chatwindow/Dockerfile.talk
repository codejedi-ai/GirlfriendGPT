# GirlfriendGPT frontend — Vite (React) Talk UI
FROM node:22-alpine
WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm install

COPY index.html vite.config.ts tsconfig.json ./
COPY src ./src
COPY .env.example ./

RUN npm run build

ENV VITE_BACKEND_PROXY=http://backend:8080
EXPOSE 5173

# Serve the Vite build; /api is proxied to app/backend
CMD ["npm", "run", "preview", "--", "--host", "0.0.0.0", "--port", "5173"]
